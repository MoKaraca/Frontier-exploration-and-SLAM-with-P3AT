# Auto detect text files and normalize line endings to LF
* text=auto

# C++ files
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cc text eol=lf

# Python files
*.py text eol=lf

# XML/Config files
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.launch text eol=lf
*.xacro text eol=lf
*.urdf text eol=lf
*.sdf text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Binary files
*.dae binary
*.blend binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.tar binary
*.gz binary

# Don't merge these files
*.dat merge=binary
*.mesh merge=binary
