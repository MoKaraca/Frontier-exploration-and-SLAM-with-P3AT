<?xml version="1.0"?>
<launch>

  <!-- Arguments -->
  <arg name="gui" default="false"/>
  <arg name="verbose" default="false"/>
  <arg name="odom_gazebo" default="p3at/odom"/>
  <arg name="traj_gazebo_odom" default="p3at/odom_traj"/>
  <arg name="world_name" default="rtg-20242-proje.world"/>
  <arg name="robot_name" default="p3at"/>

  <!-- Use simulation time -->
  <param name="/use_sim_time" value="true" />

  <!-- Robot Description -->
  <param name="robot_description_$(arg robot_name)" 
         command="$(find xacro)/xacro '$(find p3at_description)/urdf/pioneer3at.urdf.xacro' robot_name:=$(arg robot_name)" />

  <!-- Corrected: Launch Gazebo using gazebo_ros/empty_world.launch -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find hector_nist_arena_worlds)/worlds/$(arg world_name)"/>
    <arg name="paused" value="false"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="verbose" value="$(arg verbose)"/>
  </include>

  <!-- Spawn robot -->
  <group ns="p3at">
    <node pkg="gazebo_ros" type="spawn_model" name="spawn_model"
          args="-urdf -param /robot_description_$(arg robot_name) -model pioneer3at_$(arg robot_name) -x -2.4 -y 3.6 -z 1.4"/>
    <node name="trajectory" pkg="odev2" type="trajectory"/>
  </group>

  <!-- Robot State Publisher -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
    <remap from="robot_description" to="robot_description_$(arg robot_name)" />
  </node>

  <!-- Trajectory Logger -->
  <node pkg="odev2" type="trajectory" name="gazebo_odom_traj">
    <param name="odom_topic" value="$(arg odom_gazebo)" />
    <param name="traj_topic" value="$(arg traj_gazebo_odom)" />
    <param name="traj_r" value="0" />
    <param name="traj_g" value="1" />
    <param name="traj_b" value="0" />
    <param name="thres" value="0.25" />
  </node>

  <!-- RViz -->
  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find odev2)/rviz/odev2.rviz"/>

  <!-- move_base -->
  <node pkg="move_base" type="move_base" name="move_base" output="screen">
    <rosparam file="$(find odev2)/nav_params/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find odev2)/nav_params/costmap_common_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find odev2)/nav_params/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find odev2)/nav_params/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find odev2)/nav_params/base_local_planner_params.yaml" command="load" />
    <rosparam file="$(find odev2)/nav_params/move_base_params.yaml" command="load" />
    <param name="base_global_planner" value="navfn/NavfnROS" />
    <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS" />
    <remap from="cmd_vel" to="p3at/cmd_vel" />
  </node>

  <!-- Static TF: base_link to laser -->
  <node pkg="tf" type="static_transform_publisher" name="base_link_to_laser" 
        args="0 0 0 0 0 0 p3at/base_link p3at/base_laser 100"/>

  <!-- SLAM Gmapping -->
  <node pkg="gmapping" type="slam_gmapping" name="slam_gmapping" output="screen">
    <remap from="scan" to="/p3at/scan"/>
    <param name="base_frame" value="p3at/base_link"/>
    <param name="odom_frame" value="p3at/odom"/>
    <param name="map_frame" value="map"/>
    <param name="map_update_interval" value="5.0"/>
    <param name="maxUrange" value="6.0"/>
    <param name="maxRange" value="8.0"/>
    <param name="sigma" value="0.05"/>
    <param name="kernelSize" value="1"/>
    <param name="lstep" value="0.05"/>
    <param name="astep" value="0.05"/>
    <param name="iterations" value="5"/>
    <param name="lsigma" value="0.075"/>
    <param name="ogain" value="3.0"/>
    <param name="lskip" value="0"/>
    <param name="minimumScore" value="200"/>
    <param name="srr" value="0.01"/>
    <param name="srt" value="0.02"/>
    <param name="str" value="0.01"/>
    <param name="stt" value="0.02"/>
    <param name="linearUpdate" value="0.5"/>
    <param name="angularUpdate" value="0.436"/>
    <param name="temporalUpdate" value="-1.0"/>
    <param name="resampleThreshold" value="0.5"/>
    <param name="particles" value="80"/>
    <param name="xmin" value="-1.0"/>
    <param name="ymin" value="-1.0"/>
    <param name="xmax" value="1.0"/>
    <param name="ymax" value="1.0"/>
    <param name="delta" value="0.05"/>
    <param name="llsamplerange" value="0.01"/>
    <param name="llsamplestep" value="0.01"/>
    <param name="lasamplerange" value="0.005"/>
    <param name="lasamplestep" value="0.005"/>
  </node>
  
  <!-- Object Detector -->
  <node pkg="odev2" type="object_detector" name="object_detector" output="screen">
    <param name="robot_name" value="$(arg robot_name)"/>
  </node>
  
  <!-- Frontier Explorer -->
  <node pkg="odev2" type="frontier_explorer" name="frontier_explorer" output="screen">
    <param name="min_frontier_size" value="20"/>
    <param name="info_radius" value="1.0"/>
    <param name="planner_frequency" value="1.0"/>
    <param name="visualize" value="true"/>
  </node>

  <!-- Hazmat Detector -->
  <node name="hazmat_detector" pkg="odev2" type="hazmat_detector" output="screen"/>
  
  <!-- QR Code Detector -->
  <node name="qr_detector" pkg="odev2" type="qr.py" output="screen">
    <remap from="/p3at/camera/rgb/image_raw" to="/p3at/camera/rgb/image_raw"/>
    <param name="window_name" value="QR Code Detector"/>
    <param name="window_width" value="800"/>
    <param name="window_height" value="600"/>
  </node>
  
</launch>
